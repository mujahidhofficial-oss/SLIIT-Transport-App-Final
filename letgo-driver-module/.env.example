PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/letgo_transport
JWT_SECRET=replace-with-strong-secret

# Optional toggles for local/dev speed.
SKIP_LICENSE_OCR=true
SKIP_VEHICLE_BOOK_OCR=true

# Passenger signup OTP via email (Nodemailer)
REQUIRE_SIGNUP_OTP=true
OTP_EXPIRES_MIN=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="SLIIT Transport <your-email@gmail.com>"
